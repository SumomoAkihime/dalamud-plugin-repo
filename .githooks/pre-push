#!/usr/bin/env bash
set -euo pipefail

# Guardrail: prevent accidentally shipping multiple plugin payloads in one root-repo push.
# Override intentionally by adding "[multi-project-ok]" in the commit message.

range="${1:-HEAD~1..HEAD}"
if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
  changed_files="$(git diff --name-only HEAD~1..HEAD)"
else
  changed_files="$(git diff-tree --no-commit-id --name-only -r HEAD)"
fi

if [ -z "${changed_files}" ]; then
  exit 0
fi

if git log -1 --pretty=%B | grep -qi "\[multi-project-ok\]"; then
  exit 0
fi

projects=0
echo "${changed_files}" | grep -q '^plugin-repo/plugins/BossMod/' && projects=$((projects + 1))
echo "${changed_files}" | grep -q '^plugin-repo/plugins/WrathComboCN/' && projects=$((projects + 1))
echo "${changed_files}" | grep -q '^plugin-repo/plugins/CharacterPanelRefined/' && projects=$((projects + 1))

if [ "${projects}" -gt 1 ]; then
  echo "pre-push blocked: latest commit touches multiple plugin payloads." >&2
  echo "Split into separate pushes, or add [multi-project-ok] to commit message if intentional." >&2
  exit 1
fi

exit 0
